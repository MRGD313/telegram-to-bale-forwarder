# Private forum group -> per-topic Bale channels
# 1) Copy to .env.private and fill secrets
# 2) py scripts/list_forum_topics.py  (get topic_id + names)
# 3) py scripts/verify_bale_channels.py

API_ID=
API_HASH=
BALE_BOT_TOKEN=
TELEGRAM_PHONE=

# Network: auto-detect (default). Uncomment only to override:
# NETWORK_MODE=direct
# NETWORK_MODE=proxy
# LOCAL_HTTP_PROXY=http://127.0.0.1:10808
# TELEGRAM_PROXY_URL=socks5://127.0.0.1:10808

SOURCE_TO_BALE_MAPPING=https://t.me/+YourInviteHash->@FallbackBaleChannel
STRICT_TOPIC_ROUTING_SOURCES=https://t.me/+YourInviteHash
# Only listed topics are forwarded; others skipped
TOPIC_TO_BALE_MAPPING=2->@topic_bale_a;4->@topic_bale_b;6->@topic_bale_c
# Optional: crawl/send only these topic ids (faster)
INCLUDE_SEND_TOPIC_IDS=2,4,6
# Forum "General" topic id is usually 1
EXCLUDE_SEND_TOPIC_IDS=1
EXCLUDE_SEND_NULL_TOPIC=0
FORCE_BALE_CHAT=

DB_PATH=state_private.db
MODE=daemon
BACKFILL_LIMIT=0
DAEMON_INITIAL_CRAWL=1
# On restart, skip full history crawl if state.db queue already has rows (faster, less session lock)
DAEMON_SKIP_CRAWL_IF_QUEUED=1

STRICT_SEND_ORDER=1
SEND_TOPIC_BY_TOPIC=1
RESET_SENT_ON_SEND_START=0
SEND_AUTO_RETRY_ON_FAILURE=1
SEND_RETRY_DELAY_SECONDS=90
SEND_BATCH_SIZE=50
MAX_RETRIES=5

PER_MESSAGE_DELAY_SECONDS=1.0
DOWNLOAD_TIMEOUT_SECONDS=600
UPLOAD_TIMEOUT_SECONDS=300
UPLOAD_SEC_PER_MB=180
MAX_UPLOAD_TIMEOUT_SECONDS=7200

AUDIO_REENCODE_ENABLE=1
AUDIO_REENCODE_MIN_MB=12
AUDIO_OPUS_BITRATE=64k
AUDIO_OPUS_BITRATE_FLOOR=40k
# Large lecture MP3 (>95MB): split by time, upload parts (caption on part 1 only).
AUDIO_SPLIT_ENABLE=1
AUDIO_SPLIT_ABOVE_MB=95
AUDIO_SPLIT_CHUNK_MB=45
AUDIO_SPLIT_MIN_PARTS=2
AUDIO_SPLIT_MAX_PARTS=8
MEDIA_REENCODE_ON_FAIL=1
COMPRESS_SMALL_FIRST=1
COMPRESS_BEFORE_UPLOAD_MB_AUDIO=1.5
COMPRESS_BEFORE_UPLOAD_MB_VIDEO=3
COMPRESS_BEFORE_UPLOAD_MB_IMAGE=0.8
COMPRESS_TARGET_MAX_MB=18
VIDEO_REENCODE_MAX_HEIGHT=480
VIDEO_REENCODE_CRF=30
IMAGE_REENCODE_MAX_EDGE=1280
IMAGE_JPEG_Q=4
BALE_FALLBACK_TELEGRAM_LINK=1
# Only these media types may post t.me link after upload fails (default: video only)
BALE_FALLBACK_TELEGRAM_LINK_BUCKETS=video
UPLOAD_AUDIO_MAX_LINK_ONLY_MB=0
UPLOAD_AUDIO_SEC_PER_MB=90
UPLOAD_AUDIO_READ_MAX_SECONDS=1200
UPLOAD_AUDIO_LOW_CONFIDENCE_MAX_ATTEMPTS=4
BALE_ALBUM_GATEWAY_FAIL_RETRY_ONLY=1
# FFMPEG_PATH=ffmpeg

DAEMON_SUPERVISOR=1
TELEGRAM_RECOVER_DELAY_SECONDS=15
# Unattended: wait with backoff when Iran/VPN drops; resume without manual restart
SEND_NETWORK_RETRY_UNLIMITED=1
NETWORK_RETRY_BASE_SECONDS=60
NETWORK_RETRY_MAX_SECONDS=600
TELEGRAM_DOWNLOAD_TIMEOUT_RETRY=1
TELEGRAM_SESSION_SQLITE_BUSY_TIMEOUT=30

BALE_PHOTO_ALBUM_MEDIA_GROUP=1
BALE_DOCUMENT_ALBUM_MEDIA_GROUP=1
BALE_TEXT_FORMAT=plain_links
