API_ID=12345678
API_HASH=your_telegram_api_hash_here
BALE_BOT_TOKEN=botxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SOURCE_TO_BALE_MAPPING=@your_public_channel->-1001111111111;https://t.me/+yourInviteHash->-1003333333333|footer
# Optional after bale id: |inline |newline |footer (overrides BALE_PLAIN_LINK_APPEND for that source only).
MODE=daemon
BACKFILL_LIMIT=0
DAEMON_INITIAL_CRAWL=1
PER_MESSAGE_DELAY_SECONDS=1.0
DOWNLOAD_TIMEOUT_SECONDS=180
UPLOAD_TIMEOUT_SECONDS=240
# Bale upload read timeout grows with file size: min(MAX, max(UPLOAD, MB * PER_MB))
UPLOAD_SEC_PER_MB=180
MAX_UPLOAD_TIMEOUT_SECONDS=7200
# Large audio (MB): re-encode to Opus before upload (not bit-identical; high bitrate ~ transparent for voice)
AUDIO_REENCODE_ENABLE=1
AUDIO_REENCODE_MIN_MB=15
AUDIO_OPUS_BITRATE=128k
# Iran/Bale: small files upload better; quality kept usable on phones.
MEDIA_REENCODE_ON_FAIL=1
COMPRESS_SMALL_FIRST=1
COMPRESS_BEFORE_UPLOAD_MB_AUDIO=1.5
COMPRESS_BEFORE_UPLOAD_MB_VIDEO=3
COMPRESS_BEFORE_UPLOAD_MB_IMAGE=0.8
COMPRESS_TARGET_MAX_MB=18
AUDIO_OPUS_BITRATE=64k
AUDIO_OPUS_BITRATE_FLOOR=40k
VIDEO_REENCODE_MAX_HEIGHT=480
VIDEO_REENCODE_CRF=30
# fast = quicker encode for large lecture videos (default fast)
VIDEO_REENCODE_PRESET=fast
# Upload timeouts for video only (default 40s/MB, cap 600s — avoids 30+ min stalls)
VIDEO_UPLOAD_SEC_PER_MB=40
VIDEO_UPLOAD_READ_MAX_SECONDS=600
# Above this MB: never upload raw file; compress first or Telegram link
VIDEO_SKIP_RAW_UPLOAD_ABOVE_MB=5
# Above this MB: one ffmpeg pass instead of 3-step ladder
VIDEO_FAST_SINGLE_PASS_ABOVE_MB=10
VIDEO_TRY_DOCUMENT_FIRST=1
# Upload confidence (skip slow tiers when estimated Bale upload is unlikely)
# UPLOAD_CONFIDENCE=1
# VIDEO_POST_COMPRESS_ESTIMATE_RATIO=0.14
# UPLOAD_ESTIMATE_SKIP_TO_LINK_MB=16
# UPLOAD_ESTIMATE_MAX_READ_SECONDS=420
# UPLOAD_VIDEO_MAX_ENCODE_SOURCE_MB=48
# UPLOAD_VIDEO_LOW_CONFIDENCE_MB=22
# UPLOAD_LOW_CONFIDENCE_MAX_ATTEMPTS=2
# UPLOAD_LOW_CONFIDENCE_READ_CAP=360
# UPLOAD_AUDIO_LOW_CONFIDENCE_MB=28
IMAGE_REENCODE_MAX_EDGE=1280
IMAGE_JPEG_Q=4
BALE_FALLBACK_TELEGRAM_LINK=1
DB_PATH=state.db
MAX_RETRIES=3
# Bale multipart uploads: attempts per endpoint (sendPhoto vs sendDocument, etc.)
BALE_MEDIA_UPLOAD_ATTEMPTS=5
# Seconds; backoff grows (cap 45s) after each HTTP 5xx from Bale.
BALE_5XX_BACKOFF_SECONDS=2
# 1 = try sendDocument before sendPhoto for images (often more reliable on Bale).
SEND_IMAGE_AS_DOCUMENT_FIRST=1
# 1 = if all tries with caption fail, retry uploads without caption (isolates multipart/caption issues).
BALE_RETRY_MEDIA_WITHOUT_CAPTION=1
# 1 = after image upload failures, ffmpeg re-encode to baseline JPEG and retry once (helps picky Bale ingest).
BALE_REENCODE_IMAGE_ON_FAILURE=1
# BALE_TEXT_FORMAT: plain_links (default) | html | markdown | rich (HTML hyperlinks, else plain_links).
# Aliases: plain -> plain_links; auto|hybrid -> rich.
# BALE_TEXT_FORMAT=plain_links
# BALE_TEXT_FORMAT=rich
# Private groups / RTL: try BALE_PLAIN_LINK_APPEND=newline or footer (used when format falls back to plain).
# BALE_PLAIN_LINK_APPEND=inline
# BALE_PLAIN_LINK_APPEND=newline
# BALE_PLAIN_LINK_APPEND=footer
# BALE_LINK_LTR_MARK=1  # U+200E before inline "(https://…)" for RTL; not inside URL (Bale Web linkify).
# 1 = photo-only Telegram albums sent as one Bale gallery (sendMediaGroup); 0 = always separate uploads.
# BALE_PHOTO_ALBUM_MEDIA_GROUP=1
# 1 = document-only Telegram albums (e.g. PDF packs) sent as one sendMediaGroup; 0 = separate uploads.
# BALE_DOCUMENT_ALBUM_MEDIA_GROUP=1
# sendMediaGroup: TCP connect timeout (seconds); raise if document uploads abort early.
# BALE_MEDIA_GROUP_CONNECT_SECONDS=90
# Max PDFs/files per document sendMediaGroup (2–10); lower = smaller multipart, fewer timeouts.
# BALE_DOCUMENT_MEDIA_GROUP_MAX_FILES=4
# Extra read-timeout scale for document groups only (e.g. 2.0 = double).
# BALE_DOCUMENT_MEDIA_GROUP_TIMEOUT_MULTIPLIER=2.0
SEND_BATCH_SIZE=50
STRICT_SEND_ORDER=1
SEND_TOPIC_BY_TOPIC=1
# If set (semicolon/comma topic ids), MODE=send only loads queue rows with those topic_id values (forum subset test).
# INCLUDE_SEND_TOPIC_IDS=6
# If 1, each send run replays from first message. Use 0 for resume / unattended (default).
RESET_SENT_ON_SEND_START=0
# Strict order: on failure at X, wait and retry X (never send X+1) until MAX_RETRIES.
SEND_AUTO_RETRY_ON_FAILURE=1
SEND_RETRY_DELAY_SECONDS=90
# MODE=daemon: crawl (if DAEMON_INITIAL_CRAWL=1) + send + live queue for new Telegram posts.
# DAEMON_INITIAL_CRAWL=1
# Skip forum topic IDs during send (e.g. 1 = General). Semicolon or comma list.
# EXCLUDE_SEND_TOPIC_IDS=1
# EXCLUDE_SEND_NULL_TOPIC=1
# Optional: send all to one Bale chat for testing (overrides topic routing AND every row's bale_chat_id).
# While set, nothing goes to the channel in SOURCE_TO_BALE_MAPPING — only here. Unset for public-channel tests.
# FORCE_BALE_CHAT=@tebbecartest
# --- Production workflow (recommended) ---
# Use MODE=crawl (or crawl_then_send) then MODE=send — NOT backfill/live for full history + strict order.
# Run public channel and private forum as SEPARATE profiles (separate .env + DB_PATH) so queues never mix.
#
# Public (.env.public):  SOURCE_TO_BALE_MAPPING=@YourPublic->@YourBale
#   DB_PATH=state.db  STRICT_TOPIC_ROUTING_SOURCES=  FORCE_BALE_CHAT=
#   SEND_TOPIC_BY_TOPIC=1  STRICT_SEND_ORDER=1  RESET_SENT_ON_SEND_START=0
#   MODE=daemon  BACKFILL_LIMIT=0  DAEMON_INITIAL_CRAWL=1
#
# Private (.env.private): SOURCE_TO_BALE_MAPPING=https://t.me/+InviteHash->@fallback_bale
#   STRICT_TOPIC_ROUTING_SOURCES=https://t.me/+InviteHash
#   TOPIC_TO_BALE_MAPPING=6->@topic6_bale;7->@topic7_bale;1->skip
#   (topics not listed are skipped; use topic_id->skip to block explicitly)
#   DB_PATH=state_private.db  EXCLUDE_SEND_TOPIC_IDS=1
#   MODE=daemon  RESET_SENT_ON_SEND_START=0
#
# MODE=daemon keeps running: new Telegram posts are queued and sent with the same order/rules.
